[core]
	whitespace = space-before-tab,-indent-with-non-tab,trailing-space,cr-at-eol
	autocrlf = false
	safecrlf = true

[apply]
	whitespace = warn

[color]
	ui = auto

[color "branch"]
	current = yellow reverse
	local = yellow
	remote = green

[color "diff"]
	meta = yellow bold
	frag = magenta bold
	old = red
	new = green
	whitespace = red reverse

[color "status"]
	added = yellow
	changed = green
	untracked = cyan
